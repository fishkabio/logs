{
  "name": "@fishka/logs",
  "description": "Console.log transformation pipes",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "private": false,
  "sideEffects": false,
  "scripts": {
    "prebuild": "npm run clean",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build": "npm run build:esm && npm run build:cjs",
    "clean": "rimraf ./dist",
    "lint": "eslint .",
    "test": "jest --runInBand",
    "release": "npm run clean && npm run build && npm run lint && npm run test && npm publish"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^10.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=10"
  },
  "files": [
    "dist/**/*",
    "src",
    "index.ts"
  ],
  "keywords": [
    "logging",
    "console",
    "log",
    "json",
    "console.log",
    "console.debug"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fishkabio/logs.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
